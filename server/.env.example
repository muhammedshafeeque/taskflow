# -----------------------------------------------------------------------------
# Core (see src/config/env.ts)
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/pm-tool

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Frontend / links
# APP_URL: default base URL for the app (emails, Azure redirect fallback).
# FRONTEND_URL: used for user-invite email links; set to your SPA origin if unset breaks invites.
# -----------------------------------------------------------------------------
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Email (SMTP_* preferred; EMAIL_* aliases are supported)
# Leave unset if you do not send mail (forgot password, invites, etc.).
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@taskflow.local
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_FROM=

# -----------------------------------------------------------------------------
# Web Push (browser notifications)
# -----------------------------------------------------------------------------
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Enterprise: max registered users (omit or empty = no limit)
# -----------------------------------------------------------------------------
# MAX_USERS=100

# -----------------------------------------------------------------------------
# Microsoft / Azure AD SSO (optional)
# -----------------------------------------------------------------------------
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=common
# AZURE_REDIRECT_URI=http://localhost:5173/login
# MS_USER_INFO_ENDPOINT=https://graph.microsoft.com/oidc/userinfo
# MS_TOKEN_ENDPOINT=

# -----------------------------------------------------------------------------
# create-super-admin script (npm run create-super-admin)
# Optional non-interactive values; otherwise the script prompts.
# -----------------------------------------------------------------------------
# SUPER_ADMIN_EMAIL=admin@example.com
# SUPER_ADMIN_PASSWORD=
# SUPER_ADMIN_NAME=Super Admin
